POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=ai_web_db
POSTGRES_PORT=5433
POSTGRES_IMAGE=postgres:16.9-alpine

API_PORT=8000
UI_PORT=8501
PYTHON_IMAGE=python:3.11-slim

DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/ai_web_db
APP_TITLE=Multi-session LLM Chat Service
MAX_PROMPT_LENGTH=5000
API_KEY_HEADER_NAME=X-API-Key

LLM_MODE=mock
LLM_PROVIDER=groq
LLM_API_KEY=
LLM_MODEL=llama-3.1-8b-instant
LLM_BASE_URL=https://api.groq.com/openai/v1

CORS_ALLOW_ORIGINS=["http://localhost:8501","http://127.0.0.1:8501","http://localhost:3000","http://127.0.0.1:3000"]
